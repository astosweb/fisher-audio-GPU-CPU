# Performance (GPU)
# FISH_MAX_SEQ_LEN=4096   # lower KV cache; 4096 is ~1.7x faster than 32768
# FISH_COMPILE=1          # torch.compile (~10x vs no compile on GPU)
# FISH_WARMUP=1           # compile kernels at startup, not on first request
# FISH_HALF=0             # use fp16 instead of bf16 on older GPUs
